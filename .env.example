# Local development settings. Rerun the setup script to change these values.
APP_PORT=3000

# Postmark contact form settings.
# POSTMARK_FROM_EMAIL must be a verified sender signature or use a verified domain in Postmark.
POSTMARK_SERVER_TOKEN=<apikey>
POSTMARK_FROM_EMAIL=
CONTACT_EMAIL_TO=

# Cloudflare Turnstile settings.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY is safe for the browser and is loaded at runtime by the widget.
# TURNSTILE_SECRET_KEY must stay server-side.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
