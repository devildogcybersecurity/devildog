# Local development settings. Rerun the setup script to change these values.
APP_PORT=3000
POSTGRES_PORT=5432
POSTGRES_DB=mvp_template
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mvp_template?schema=public
DOCKER_DATABASE_URL=postgresql://postgres:postgres@db:5432/mvp_template?schema=public
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Optional OAuth provider settings. Leave blank until you have credentials.
MICROSOFT_ENTRA_CLIENT_ID=
MICROSOFT_ENTRA_CLIENT_SECRET=
MICROSOFT_ENTRA_TENANT_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
